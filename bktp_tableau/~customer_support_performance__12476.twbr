      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0d4ovs50tn5ymn18xf7jy1xb1b8a].[avg:Calculation_0857399530848257:qk]&quot;' value='Basic Intervention' />
          <alias key='&quot;[federated.0d4ovs50tn5ymn18xf7jy1xb1b8a].[avg:Calculation_0857400585555971:qk]&quot;' value='Structural Intervention' />
          <alias key='&quot;[federated.0d4ovs50tn5ymn18xf7jy1xb1b8a].[avg:resolution_time_hours:qk]&quot;' value='No Action' />
        </aliases>
      </column>
      <column caption='Adjusted Resolution Time' datatype='real' name='[Calculation_0802423596134400]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [team] = &quot;Technical Support&quot; THEN [resolution_time_hours] * 0.85&#13;&#10;ELSE [resolution_time_hours]&#13;&#10;END' />
      </column>
      <column caption='Intervention Start' datatype='boolean' name='[Calculation_0857399530471424]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[ticket_created_at] &gt;= DATE(&quot;2023-01-01&quot;)' />
      </column>
      <column caption='Improved Resolution Time' datatype='real' name='[Calculation_0857399530848257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [ticket_created_at] &gt;= DATE(&quot;2022-01-01&quot;) THEN&#13;&#10;    [resolution_time_hours] * 0.50&#13;&#10;ELSE&#13;&#10;    [resolution_time_hours]&#13;&#10;END' />
      </column>
      <column caption='Improved SLA Breach Flag' datatype='integer' name='[Calculation_0857399542042626]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0857399530848257] &gt; [sla_target_hours] THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Aggressive Intervention Resolution Time' datatype='real' name='[Calculation_0857400585555971]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [ticket_created_at] &gt;= DATE(&quot;2022-01-01&quot;) THEN&#13;&#10;    ([resolution_time_hours] * 0.5) - 20&#13;&#10;ELSE&#13;&#10;    [resolution_time_hours]&#13;&#10;END' />
      </column>
      <column caption='Aggresive SLA Breach Flag' datatype='integer' name='[Calculation_0857400586563589]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_0857400585555971] &gt; [sla_target_hours] THEN 1&#13;&#10;ELSE 0&#13;&#10;END' />
      </column>
      <column caption='Basic Improvement %' datatype='real' name='[Calculation_0857400594931718]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([resolution_time_hours]) - AVG([Calculation_0857399530848257]))&#13;&#10;/ AVG([resolution_time_hours])' />
      </column>
      <column caption='SLA breach numeric' datatype='integer' default-format='p0.0%' name='[Calculation_1381588849340416]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [sla_breached] = &quot;Yes&quot; THEN 1 ELSE 0 END' />
      </column>
